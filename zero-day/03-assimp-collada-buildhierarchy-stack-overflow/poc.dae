<?xml version="1.0"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
<library_nodes>
  <node id="nodeA" name="A" type="NODE">
    <instance_node url="#nodeB"/>
  </node>
  <node id="nodeB" name="B" type="NODE">
    <instance_node url="#nodeA"/>
  </node>
</library_nodes>
<library_visual_scenes>
  <visual_scene id="scene">
    <node id="root" type="NODE">
      <instance_node url="#nodeA"/>
    </node>
  </visual_scene>
</library_visual_scenes>
<scene><instance_visual_scene url="#scene"/></scene>
</COLLADA>
