#!/bin/bash
# Drop-in replacement for the ARVO in-container script (`/usr/bin/arvo`).
# Provides the same interface as n132/arvo Docker images so that vulagent
# agents can interact with OSS-Fuzz-built containers identically.
#
# Layout:  /out/{asan,ubsan,msan}/<fuzzer_binaries>
#
# Interface:
#   arvo                  — run default fuzzer (SANITIZER, default: asan)
#   arvo list             — list fuzzers for current SANITIZER
#   arvo list --all       — list fuzzers across all sanitizers
#   arvo run <f> [poc]    — run fuzzer <f> with PoC (default: /tmp/poc)
#   arvo targets <sym>    — list fuzz targets whose binary contains <sym>
#   arvo compile          — recompile via OSS-Fuzz compile command
#
# Environment:
#   SANITIZER       — asan | ubsan | msan  (default: asan)
#   DEFAULT_FUZZER  — override auto-detection of the default fuzzer binary

# Sanitizer env vars — mirrors OSS-Fuzz base-runner / ARVO defaults
export ASAN_OPTIONS="alloc_dealloc_mismatch=0:allocator_may_return_null=1:allocator_release_to_os_interval_ms=500:check_malloc_usable_size=0:detect_container_overflow=1:detect_odr_violation=0:detect_leaks=0:detect_stack_use_after_return=1:fast_unwind_on_fatal=0:handle_abort=1:handle_segv=1:handle_sigill=1:max_uar_stack_size_log=16:print_scariness=1:quarantine_size_mb=10:strict_memcmp=1:strip_path_prefix=/workspace/:symbolize=1:use_sigaltstack=1:dedup_token_length=3"
export MSAN_OPTIONS="print_stats=1:strip_path_prefix=/workspace/:symbolize=1:dedup_token_length=3"
export UBSAN_OPTIONS="print_stacktrace=1:print_summary=1:silence_unsigned_overflow=1:strip_path_prefix=/workspace/:symbolize=1:dedup_token_length=3"
export FUZZER_ARGS="-rss_limit_mb=2560 -timeout=25"
export AFL_FUZZER_ARGS="-m none"

SANITIZER="${SANITIZER:-asan}"
OUT_DIR="/out"
POC_FILE=/tmp/poc

fuzz_dir() { echo "$OUT_DIR/$SANITIZER"; }

is_fuzzer() {
    [ -f "$1" ] && [ -x "$1" ] && file "$1" 2>/dev/null | grep -q "ELF"
}

list_fuzzers() {
    local dir="$1"
    for f in "$dir"/*; do
        is_fuzzer "$f" && basename "$f"
    done
}

list_all() {
    for san_dir in "$OUT_DIR"/*/; do
        local san
        san=$(basename "$san_dir")
        local fuzzers
        mapfile -t fuzzers < <(list_fuzzers "$san_dir")
        if [ ${#fuzzers[@]} -gt 0 ]; then
            printf "[%s]\n" "$san"
            printf "  %s\n" "${fuzzers[@]}"
        fi
    done
}

get_default_fuzzer() {
    local dir
    dir=$(fuzz_dir)
    if [ ! -d "$dir" ]; then
        echo "ERROR: no $SANITIZER build found at $dir" >&2
        echo "Available: $(ls "$OUT_DIR"/ 2>/dev/null | tr '\n' ' ')" >&2
        return 1
    fi
    if [ -n "$DEFAULT_FUZZER" ]; then
        echo "$dir/$DEFAULT_FUZZER"
        return 0
    fi
    if [ -f "$dir/.default_fuzzer" ]; then
        echo "$dir/$(cat "$dir/.default_fuzzer")"
        return 0
    fi
    local fuzzers
    mapfile -t fuzzers < <(list_fuzzers "$dir")
    if [ ${#fuzzers[@]} -eq 1 ]; then
        echo "$dir/${fuzzers[0]}"
    elif [ ${#fuzzers[@]} -eq 0 ]; then
        echo "ERROR: no fuzzer binaries in $dir" >&2
        return 1
    else
        echo "ERROR: multiple fuzzers in $dir — use 'arvo run <fuzzer>' or set DEFAULT_FUZZER" >&2
        printf "  %s\n" "${fuzzers[@]}" >&2
        return 1
    fi
}

find_targets_for_symbol() {
    local symbol="$1"
    local dir
    dir=$(fuzz_dir)
    [ -d "$dir" ] || return 1
    for f in "$dir"/*; do
        is_fuzzer "$f" || continue
        if nm "$f" 2>/dev/null | grep -q -w "$symbol"; then
            basename "$f"
        fi
    done
}

case "${1:-}" in
    list)
        if [ "${2:-}" = "--all" ]; then
            list_all
        else
            list_fuzzers "$(fuzz_dir)"
        fi
        ;;
    run)
        fuzzer="${2:?Usage: arvo run <fuzzer> [poc_path]}"
        exec "$(fuzz_dir)/$fuzzer" "${3:-$POC_FILE}"
        ;;
    targets)
        symbol="${2:?Usage: arvo targets <symbol>}"
        find_targets_for_symbol "$symbol"
        ;;
    compile)
        exec compile
        ;;
    "")
        fuzzer=$(get_default_fuzzer) || exit 1
        exec "$fuzzer" "$POC_FILE"
        ;;
    *)
        echo "Unknown command: $1" >&2
        echo "Usage: arvo [list [--all] | run <fuzzer> [poc] | targets <sym> | compile]" >&2
        echo "Environment: SANITIZER=asan|ubsan|msan (default: asan)" >&2
        exit 1
        ;;
esac
