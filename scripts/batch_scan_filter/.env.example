# Copy this file to `.env` (same directory) and fill in real keys.
#
#   cp scripts/batch_scan_filter/.env.example scripts/batch_scan_filter/.env
#   chmod 600 scripts/batch_scan_filter/.env
#
# The batch runner loads this file via `ENV_FILE=...`, e.g.:
#   ENV_FILE=scripts/batch_scan_filter/.env \
#     scripts/batch_scan_filter.sh scripts/batch_scan_filter/jobs.tsv
#
# Lines are parsed as KEY=VALUE. Comments and blank lines are ignored.
# The env-var NAME (not the value) is what appears in `api_key_env` column
# of jobs.tsv; rows can share names to reuse a single key across projects.
# `.env` itself is .gitignored. Do not commit real keys.

# Anthropic direct API keys (sk-ant-...). Used by rows whose model is
# `anthropic/claude-...` and whose api_key_env is ANTHROPIC_KEY_1/_2.
ANTHROPIC_KEY_1=sk-ant-REPLACE_ME
ANTHROPIC_KEY_2=sk-ant-REPLACE_ME

# OpenRouter key (sk-or-...). Used by rows whose model is
# `openrouter/anthropic/claude-...` and whose api_key_env is OPENROUTER_KEY.
# Handy as an overflow key when an Anthropic workspace hits its spend cap.
OPENROUTER_KEY=sk-or-REPLACE_ME
